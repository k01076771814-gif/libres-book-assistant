# Server
PORT=3000
PUBLIC_BASE_URL=https://your-domain.example
APP_ORIGIN=https://your-domain.example

# Storage
DATA_DIR=./data
DATABASE_URL=
DATABASE_SSL=false

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=

# Telegram Payments
TELEGRAM_PAYMENT_PROVIDER_TOKEN=
PREMIUM_MONTHLY_PRICE_KOPEKS=19900
PREMIUM_YEARLY_PRICE_KOPEKS=150000

# Development fallback. Set false in production after payments are connected.
ALLOW_MOCK_PAYMENTS=true
